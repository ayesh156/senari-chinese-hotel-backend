generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ─── Enums ─────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  CASHIER
  STAFF
}

enum CategoryType {
  FOOD
  INVENTORY
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIAL
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

enum POStatus {
  PAID
  UNPAID
  PARTIAL
}

// ─── Core Models ───────────────────────────────────────────────────────────────

/// Staff user accounts for POS login
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?  @unique
  phone     String?
  password  String   @default("")
  role      UserRole @default(STAFF)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  orders Order[] // Cashier who processed the order

  @@map("users")
}

/// Shared categories table — used for both food categories and inventory categories
model Category {
  id        Int          @id @default(autoincrement())
  name      String       @unique
  type      CategoryType // FOOD or INVENTORY
  createdAt DateTime     @default(now())

  foodItems      FoodItem[]      @relation("FoodCategory")
  inventoryItems InventoryItem[] @relation("InventoryCategory")

  @@map("categories")
}

/// Measurement units (e.g., kg, liters, packets, pcs)
model Unit {
  id            Int              @id @default(autoincrement())
  name          String           @unique
  abbreviation  String
  createdAt     DateTime         @default(now())

  inventoryItems InventoryItem[]

  @@map("units")
}

/// Menu items available for ordering
model FoodItem {
  id          Int      @id @default(autoincrement())
  name        String
  price       Decimal  @db.Decimal(10, 2)
  categoryId  Int
  category    Category @relation("FoodCategory", fields: [categoryId], references: [id])
  description String?  @db.Text
  ingredients String?  @db.Text // JSON array stored as text
  image       String?
  calories    Int?
  prepTime    String?
  isNew       Boolean  @default(false)
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]
  sortOrder  Int       @default(0) // For manual ordering in menu display

  @@map("food_items")
}

/// Raw ingredients / stock items for inventory management
model InventoryItem {
  id               Int      @id @default(autoincrement())
  sku              String   @unique
  name             String
  categoryId       Int
  category         Category @relation("InventoryCategory", fields: [categoryId], references: [id])
  quantity         Decimal  @db.Decimal(10, 2)
  unitId           Int
  unit             Unit     @relation(fields: [unitId], references: [id])
  minAlertLevel    Decimal  @default(0) @db.Decimal(10, 2)
  unitPrice        Decimal  @db.Decimal(10, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  purchaseOrderItems PurchaseOrderItem[]
  adjustments        InventoryAdjustment[]

  @@map("inventory_items")
}

/// Customers who dine in or place orders
model Customer {
  id            Int      @id @default(autoincrement())
  name          String
  phone         String   @unique
  email         String?
  address       String?  @db.Text
  nic           String?  // National ID card number
  image         String?
  dueAmount     Decimal  @default(0) @db.Decimal(10, 2)
  reminderCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders Order[]

  @@map("customers")
}

/// Suppliers who provide inventory items
model Supplier {
  id              Int      @id @default(autoincrement())
  name            String
  phone           String?
  email           String?
  address         String?  @db.Text
  category        String?  // Free-text supplier category (e.g., Vegetables, Meat)
  payableAmount   Decimal  @default(0) @db.Decimal(10, 2)
  totalPurchases  Decimal  @default(0) @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

/// Restaurant table management
model RestaurantTable {
  id          Int         @id @default(autoincrement())
  tableNumber Int         @unique
  capacity    Int         @default(4)
  status      TableStatus @default(AVAILABLE)
  note        String?     @db.Text
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orders Order[]

  @@map("restaurant_tables")
}

/// Customer orders (dine-in, takeaway, or delivery)
model Order {
  id            Int           @id @default(autoincrement())
  invoiceNumber String        @unique
  type          OrderType     @default(DINE_IN)
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  subtotal      Decimal       @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  amountPaid    Decimal       @default(0) @db.Decimal(10, 2)
  notes         String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relationships
  customerId Int?
  customer   Customer?       @relation(fields: [customerId], references: [id])
  tableId    Int?
  table      RestaurantTable? @relation(fields: [tableId], references: [id])
  userId     Int?
  user       User?            @relation(fields: [userId], references: [id])

  items OrderItem[]

  @@map("orders")
}

/// Line items on an order (join table between Order and FoodItem)
model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  foodId    Int
  food      FoodItem @relation(fields: [foodId], references: [id])
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(10, 2)
  subtotal  Decimal  @db.Decimal(10, 2)

  @@map("order_items")
}

/// Purchase orders placed to suppliers for inventory restocking
model PurchaseOrder {
  id            Int        @id @default(autoincrement())
  poNumber      String     @unique
  supplierId    Int
  supplier      Supplier   @relation(fields: [supplierId], references: [id])
  subtotal      Decimal    @db.Decimal(10, 2)
  paidAmount    Decimal    @default(0) @db.Decimal(10, 2)
  paymentStatus POStatus   @default(UNPAID)
  notes         String?    @db.Text
  receivedAt    DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  items PurchaseOrderItem[]

  @@map("purchase_orders")
}

/// Line items on a purchase order (join table between PurchaseOrder and InventoryItem)
model PurchaseOrderItem {
  id              Int            @id @default(autoincrement())
  purchaseOrderId Int
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItemId Int
  inventoryItem   InventoryItem  @relation(fields: [inventoryItemId], references: [id])
  quantity        Decimal        @db.Decimal(10, 2)
  unitPrice       Decimal        @db.Decimal(10, 2)
  total           Decimal        @db.Decimal(10, 2)

  @@map("purchase_order_items")
}

/// Inventory stock adjustment log (additions, usage, waste, corrections)
model InventoryAdjustment {
  id              Int           @id @default(autoincrement())
  inventoryItemId Int
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  adjustmentType  String        // "New Delivery", "Daily Usage", "Damage/Waste", "Count Correction", "Other"
  quantity        Decimal       @db.Decimal(10, 2) // Positive = addition, Negative = reduction
  previousStock   Decimal       @db.Decimal(10, 2)
  newStock        Decimal       @db.Decimal(10, 2)
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())

  @@map("inventory_adjustments")
}